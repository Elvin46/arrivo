{
  "ConnectionStrings": {
    "DefaultConnection": "Server=<SERVER>;Database=<DB_NAME>;User Id=<DB_USER>;Password=<DB_PASSWORD>;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "<JWT_SECRET_KEY_MIN_32_CHARS>",
    "Issuer": "<JWT_ISSUER>",
    "Audience": "<JWT_AUDIENCE>",
    "ExpiresInMinutes": 10080
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
